{
  "pythonVersion": "3.11",
  "venvPath": ".",
  "venv": ".venv",
  "extraPaths": [
    ".",
    "airflow/dags"
  ],
  "include": [
    "src",
    "notebooks",
    "tests",
    "airflow/dags"
  ],
  "exclude": [
    "**/__pycache__",
    "**/.pytest_cache",
    ".venv"
  ],
  "reportMissingImports": "warning",
  "reportMissingModuleSource": "none",
  "reportUnknownMemberType": "none",
  "reportUnknownVariableType": "none",
  "reportUnknownArgumentType": "none",
  "reportAny": "none"
}
